{
  "title": "Account Creation Platform Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Targets Up",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 4},
      "targets": [
        {"expr": "sum(up)", "legendFormat": "up"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Traefik 5xx Responses",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 4},
      "targets": [
        {"expr": "sum(rate(traefik_service_requests_total{code=~\"5..\"}[5m]))", "legendFormat": "5xx"}
      ]
    }
  ]
}
