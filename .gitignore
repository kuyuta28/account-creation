# Root orchestration repo only.
# Service source code lives in independent repos, tracked as git submodules
# (see .gitmodules). Do NOT ignore them — submodule gitlinks need the paths visible.
# Local-only service working trees (uncommitted edits) remain inside each submodule.

# Local runtime data and backups
data/
backups/
*.db
*.db.bak
*.db.*.bak
*.dump

# Local tooling / editor state
.agents/
.claude/
__pycache__/
*.pyc
config/sops-age-key.txt

# Playwright MCP cache. Created by the chrome-devtools-mcp tool on every
# browser session; safe to delete, will be regenerated on next run.
.playwright-mcp/

# Keep orchestration and docs visible
!.github/
!docs/
!traefik/
!README.md
!docker-compose.yml
!CLAUDE.md
