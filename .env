POSTGRES_USER=ccs
POSTGRES_PASSWORD=ccs_dev_only
POSTGRES_DB=account_creator
INTERNAL_API_KEY=dev-internal-key
APP_ENV=dev

# Single source of truth for the app DSN. Compose interpolates ${DATABASE_URL}
# into every app service and into postgres init via ${POSTGRES_*} above.
DATABASE_URL=postgresql+asyncpg://ccs:ccs_dev_only@postgres:5432/account_creator

# Windows APPDATA path (POSIX-style for docker-compose mount on WSL2/Docker Desktop)
# Git Bash sẽ convert đường dẫn có "/" đầu, nên dùng WSL2-style.
APPDATA_POSIX=/c/Users/admin/AppData/Roaming

# Host Browser Agent: URL cua daemon chay tren host OS de mo browser thuc.
# Vi du tren Docker Desktop: http://host.docker.internal:9999
# Vi du khi chay registrar truc tiep tren host: http://127.0.0.1:9999
#HOST_BROWSER_AGENT_URL=
