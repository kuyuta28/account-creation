# Dev environment defaults for docker compose.
# Copy this file to .env and adjust non-default values.
# NEVER commit real secrets or production credentials.

APP_ENV=dev
INTERNAL_API_KEY=dev-internal-key
SENTRY_DSN=

# Postgres credentials. DATABASE_URL is interpolated into every app service.
POSTGRES_USER=ccs
POSTGRES_PASSWORD=ccs_dev_only
POSTGRES_DB=account_creator
DATABASE_URL=postgresql+asyncpg://ccs:ccs_dev_only@postgres:5432/account_creator

# Windows host paths (WSL2/Docker Desktop POSIX format).
# Example: /c/Users/admin/AppData/Roaming
APPDATA_POSIX=/c/Users/admin/AppData/Roaming
# Example: /c/Users/admin/AppData/Local
LOCALAPPDATA_POSIX=/c/Users/admin/AppData/Local

# 9router SQLite DB host directory (tts-proxy reads API keys from here).
NINE_ROUTER_HOST_DIR=/c/Users/admin/AppData/Roaming/9router

# Grafana credentials for observability overlay.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
